{
  "target": {
    "type": "http",
    "url": "http://localhost:8080/mcp"
  },
  "expectations": {
    "capabilities": [
      "tools",
      "logging"
    ],
    "tools": [
      {
        "name": "hello",
        "required": true
      },
      {
        "name": "countdown",
        "required": true
      },
      {
        "name": "rot-13-tool.encode",
        "required": true
      }
    ]
  },
  "suites": [
    "handshake",
    "tool-discovery",
    "tool-invocation",
    "streaming"
  ],
  "timeouts": {
    "connectMs": 5000,
    "invokeMs": 15000,
    "shutdownMs": 3000
  },
  "chaos": {
    "enable": false
  },
  "reporting": {
    "formats": [
      "json"
    ],
    "outputDir": "./reports"
  }
}
